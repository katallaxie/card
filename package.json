{
  "name": "katallaxie",
  "version": "0.0.0",
  "description": "A personal card of Sebastian Doell (@katallaxie)",
  "main": "/bin/card.js",
  "bin": {
    "katallaxie": "./bin/card.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/katallaxie/card.git"
  },
  "homepage": "https://katallaxie.dev",
  "scripts": {
    "build": "ts-node build.ts --color=16m",
    "check": "biome check",
    "clean": "rm -rf node_modules package-lock.json",
    "dev": "npm run build && node ./bin/card.js",
    "format": "biome format --write",
    "lint": "biome lint --write",
    "prepublish": "npm run build",
    "start": "./bin/card.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": ["biome check --write --no-errors-on-unmatched"]
  },
  "keywords": ["card", "npm", "npm card", "npx", "npx card", "business card"],
  "author": {
    "email": "sebastian@katallaxie.dev",
    "name": "Sebastian Doell (@katallaxie)",
    "url": "https://katallaxie.dev"
  },
  "license": "MIT",
  "files": ["bin/card.js", "bin/output"],
  "dependencies": {
    "clear": "^0.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/cli-table": "^0.3.1",
    "@types/node": "^20.4.1",
    "@typescript-eslint/eslint-plugin": "^5.61.0",
    "@typescript-eslint/parser": "^8.60.1",
    "boxen": "^8.0.1",
    "chalk": "^4.1.0",
    "cli-table": "^0.3.11",
    "console-table-printer": "^2.11.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  },
  "bugs": {
    "url": "https://github.com/katallaxie/card/issues"
  }
}
